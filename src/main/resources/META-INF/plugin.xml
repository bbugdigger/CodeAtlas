<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.bugdigger.CodeAtlas</id>
    <name>CodeAtlas</name>
    <vendor>bugdigger</vendor>

    <description><![CDATA[
        <b>CodeAtlas</b> — natural-language code navigation for IntelliJ IDEA.<br>
        Ask questions like <em>"where is authentication implemented?"</em> and jump directly to the
        matching class or method. Uses a locally-bundled embedding model; works fully offline, no
        API key required.
    ]]></description>

    <!-- Phase 1 supports Kotlin + Java. The LanguageAdapter layer is designed to accept more
         languages later without changes to the core. -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <resource-bundle>messages.CodeAtlasBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Project-level services are registered via @Service annotation (light services). -->
        <!-- Tool window, startup activity, and settings configurable are wired in Week 3. -->
    </extensions>
</idea-plugin>
