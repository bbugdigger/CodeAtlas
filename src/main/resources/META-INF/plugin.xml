<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.bugdigger.CodeAtlas</id>
    <name>CodeAtlas</name>
    <vendor>bugdigger</vendor>

    <description><![CDATA[
        <b>CodeAtlas</b> — natural-language code navigation for IntelliJ IDEA.<br>
        Ask questions like <em>"where is authentication implemented?"</em> and jump directly to the
        matching class or method. Uses a locally-bundled embedding model; works fully offline, no
        API key required.
    ]]></description>

    <!-- Phase 1 supports Kotlin + Java. The LanguageAdapter layer is designed to accept more
         languages later without changes to the core. -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>
    <depends>org.jetbrains.kotlin</depends>

    <resource-bundle>messages.CodeAtlasBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Project-level CodeAtlasIndexService is a light service (@Service annotation). -->
        <toolWindow
            id="CodeAtlas"
            anchor="right"
            icon="AllIcons.Toolwindows.ToolWindowFind"
            factoryClass="com.bugdigger.codeatlas.ui.CodeAtlasToolWindowFactory"/>
        <postStartupActivity
            implementation="com.bugdigger.codeatlas.startup.CodeAtlasStartupActivity"/>
        <projectConfigurable
            id="com.bugdigger.codeatlas.settings"
            displayName="CodeAtlas"
            instance="com.bugdigger.codeatlas.settings.CodeAtlasSettingsConfigurable"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>

    <actions>
        <action
            id="CodeAtlas.AskAction"
            class="com.bugdigger.codeatlas.actions.AskCodeAtlasAction"
            text="Ask CodeAtlas"
            description="Search CodeAtlas for the selected text, or for the symbol at the caret.">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
